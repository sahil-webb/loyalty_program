// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:data/dev.db"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model RewardCustomer {
  id        Int @id @default(autoincrement())

  shop      String
  shopifyId String

  firstName String
  lastName  String
  email     String

  birthday  String?
  discountCode String?

  points    Int @default(0)

  referralCode String?
  signInWithReferral Boolean @default(false)
  signInReferralCode String?

  tier String @default("insider")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, shopifyId])
}

model RewardRule {
  id             Int      @id @default(autoincrement())
  pointsPerUnit  Float    // e.g. 5   (points)
  currencyUnit   Float    // e.g. 1   (dollar)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}



model PremiumCustomer {
  id                 Int      @id @default(autoincrement())
  shop               String
  shopifyId          String
  email              String?

  coins              Int      @default(0)
  discountCode       String?

  referralCode       String?  @unique
  signInWithReferral Boolean  @default(false)
  signInReferralCode String?
  birthday DateTime @default("2002-04-15T00:00:00.000Z")
  tier               String   @default("insider")
  lastVisitReward    DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([shop, shopifyId])
  @@index([shop])
}

model RewardTransaction {
  id              Int      @id @default(autoincrement())

  shop            String
  shopifyId       String

  type            TransactionType
  points          Int
  availablePoints Int
  tier               String   @default("insider")
  description     String?

  orderId         String?
  referralCode    String?

  createdAt       DateTime @default(now())

  @@index([shop, shopifyId])
}

model RegularPointRule {
  id        Int      @id @default(autoincrement())
  points    Int      @unique
  discount  Int
  createdAt DateTime @default(now())
}

model PremiumPointRule {
  id        Int      @id @default(autoincrement())
  points    Int      @unique
  discount  Int
  createdAt DateTime @default(now())
}

enum TransactionType {
  EARN
  REDEEM
  REFERRAL
  REVIEW
  ORDER
  ADJUSTMENT
}